{
	# Railway terminates TLS at its edge; the docs container speaks HTTP.
	auto_https off
	admin off
}

# {$PORT:3003} lets Railway pick the port; defaults to 3003 to match the
# port the old Next.js docs runner used (kept for service-config continuity).
:{$PORT:3003} {
	root * /srv

	encode zstd gzip

	# The HTTP edge in front of this container (Railway's router / Cloudflare)
	# injects `Range: bytes=0-` on upstream requests. The docs are a static
	# HTML/CSS/JS/JSON export with no byte-range consumers (the Orama search
	# client fetches /api/search whole, not via ranges), so we drop the request
	# `Range` header before file_server runs. This makes the CADDY ORIGIN answer
	# a clean `200` with the full body instead of `206 Partial Content` (#2947).
	#
	# CAVEAT (#3185): this does NOT make the *public* response a 200. The Railway
	# edge (`x-hikari-trace`) and Cloudflare in front re-wrap the full-body origin
	# response as `206` with a whole-document `Content-Range: bytes 0-N/N+1` —
	# verified by sending `Range: bytes=0-10`, which still returns the FULL range
	# (the origin ignored the range; the edge synthesized the 206). That status is
	# edge-generated and not controllable from this Caddyfile, so strict `== 200`
	# uptime monitors for docs.useatlas.dev MUST accept `2xx` (e.g. 200, 206, 307).
	# `-Range` is kept regardless so the origin stays clean.
	request_header -Range

	# Next.js content-hashes /_next/static URLs, so they're safe to pin immutably.
	@nextStatic path /_next/static/*
	header @nextStatic Cache-Control "public, max-age=31536000, immutable"

	# OG images and the Orama search index regenerate only on rebuild — long-cache.
	# /api/search is ~24MB; revalidating every 5min would torpedo the cost win.
	@longCache path /docs-og/* /api/search
	header @longCache Cache-Control "public, max-age=86400"

	# HTML/JSON/markdown can change between deploys — short cache + revalidate.
	@shortCache {
		not path /_next/static/* /docs-og/* /api/search
	}
	header @shortCache Cache-Control "public, max-age=300, must-revalidate"

	# RFC 8288 / 9727 link relations + Vary: Accept (markdown content-negotiation)
	# apply only to HTML doc pages. Static assets, OG images, the search index,
	# .well-known JSON, and the markdown surfaces have their own content types
	# and would be cache-fragmented by Vary: Accept on a CDN.
	@docPage {
		not path /_next/* /docs-og/* /api/* /.well-known/* /llms.mdx /llms.mdx/* /llms.txt /llms-full.txt /favicon.ico /icon.svg /robots.txt /sitemap.xml
	}
	header @docPage Link `</.well-known/api-catalog>; rel="api-catalog"; type="application/linkset+json", <https://docs.useatlas.dev/api-reference/openapi.json>; rel="service-desc"; type="application/openapi+json", <https://api.useatlas.dev/api/health>; rel="status"; type="application/json", </llms.txt>; rel="alternate"; type="text/plain", </llms-full.txt>; rel="describedby"; type="text/plain", </.well-known/mcp/server-card.json>; rel="mcp-server-card"; type="application/json", </.well-known/oauth-protected-resource>; rel="oauth-protected-resource"; type="application/json", </.well-known/agent-skills/index.json>; rel="agent-skills"; type="application/json"`
	header @docPage Vary "Accept"

	# Extension-less .well-known + /api/search outputs need explicit content types.
	@apiSearch path /api/search
	header @apiSearch Content-Type "application/json; charset=utf-8"

	@wellKnownLinkset path /.well-known/api-catalog
	header @wellKnownLinkset Content-Type "application/linkset+json; charset=utf-8"

	@wellKnownJson path /.well-known/agent-skills/index.json /.well-known/mcp/server-card.json /.well-known/oauth-protected-resource
	header @wellKnownJson Content-Type "application/json; charset=utf-8"

	# /guides/mcp-hosted/* was consolidated into /guides/mcp under the
	# hosted/self-hosted tabs. The :rest* equivalent in Caddy is path_regexp +
	# {re.NAME.N}; bare and trailing-slash variants each need their own rule.
	@mcpHostedSub path_regexp mcpHostedSub ^/guides/mcp-hosted/(.+)$
	redir @mcpHostedSub /guides/mcp/{re.mcpHostedSub.1} 308
	redir /guides/mcp-hosted /guides/mcp 308
	redir /guides/mcp-hosted/ /guides/mcp/ 308

	# ── BEGIN /self-hosted section redirects (#4267) ─────────────────────────
	# Slice #4264 (PR #4283) un-tabbed the docs portal and MOVED twelve
	# self-hosted-only pages from the site root into the new /self-hosted
	# section (a clean-prefix rename: /<slug> -> /self-hosted/<slug>). Their old
	# root URLs 308-redirect to the /self-hosted counterpart so external /
	# help-center inbound links and SEO survive the move — same shape as the
	# mcp-hosted block above: an EXACT-path bare + trailing-slash pair per page
	# (file_server then does the bare -> trailing 301 at the destination). Only
	# these moved on-prem pages redirect; SaaS root URLs and /api-reference/* are
	# unchanged (#4257 locked decisions).
	#
	# SSOT for this list: apps/docs/src/lib/redirects.ts (MOVED_SELF_HOSTED_SLUGS)
	# — apps/docs/src/lib/__tests__/redirect-coverage.test.ts fails if this block
	# and that map ever drift apart, if a target 404s, or if a moved page is
	# missing a redirect. Keep the two in lockstep.
	redir /getting-started/quick-start /self-hosted/getting-started/quick-start 308
	redir /getting-started/quick-start/ /self-hosted/getting-started/quick-start/ 308
	redir /deployment/deploy /self-hosted/deployment/deploy 308
	redir /deployment/deploy/ /self-hosted/deployment/deploy/ 308
	redir /deployment/authentication /self-hosted/deployment/authentication 308
	redir /deployment/authentication/ /self-hosted/deployment/authentication/ 308
	redir /deployment/cache-configuration /self-hosted/deployment/cache-configuration 308
	redir /deployment/cache-configuration/ /self-hosted/deployment/cache-configuration/ 308
	redir /frameworks/overview /self-hosted/frameworks/overview 308
	redir /frameworks/overview/ /self-hosted/frameworks/overview/ 308
	redir /frameworks/react-vite /self-hosted/frameworks/react-vite 308
	redir /frameworks/react-vite/ /self-hosted/frameworks/react-vite/ 308
	redir /frameworks/nuxt /self-hosted/frameworks/nuxt 308
	redir /frameworks/nuxt/ /self-hosted/frameworks/nuxt/ 308
	redir /frameworks/sveltekit /self-hosted/frameworks/sveltekit 308
	redir /frameworks/sveltekit/ /self-hosted/frameworks/sveltekit/ 308
	redir /frameworks/tanstack-start /self-hosted/frameworks/tanstack-start 308
	redir /frameworks/tanstack-start/ /self-hosted/frameworks/tanstack-start/ 308
	redir /guides/self-hosted-models /self-hosted/guides/self-hosted-models 308
	redir /guides/self-hosted-models/ /self-hosted/guides/self-hosted-models/ 308
	redir /contributing/ci /self-hosted/contributing/ci 308
	redir /contributing/ci/ /self-hosted/contributing/ci/ 308
	redir /contributing/eval-harness /self-hosted/contributing/eval-harness 308
	redir /contributing/eval-harness/ /self-hosted/contributing/eval-harness/ 308
	# ── END /self-hosted section redirects (#4267) ───────────────────────────

	# ── BEGIN llms twin rewrites (#4266) ─────────────────────────────────────
	# Section-aware markdown twins for the /self-hosted section. Its machine
	# surfaces (/self-hosted/llms.txt, /self-hosted/llms-full.txt, and the
	# /self-hosted/<slug>.mdx twins) mirror the root ones but are sourced from the
	# self-hosted loader (self-hosted + shared) — so an agent reading self-hosted
	# docs is never fed the SaaS-only branch (PRD #4257). These rules route the
	# /self-hosted twin URLs onto their on-disk /self-hosted/llms.mdx/<slug>/index.md
	# emission. Two independent things keep them from colliding with the generic
	# root rules below, and BOTH are load-bearing — don't reorder AND don't drop a
	# guard: (a) source order — these run first, which is what protects the bare
	# landing /self-hosted.mdx (NOT under /self-hosted/*, so the generic @mdxAlias's
	# `not path /self-hosted/*` guard does NOT exclude it); and (b) the
	# `not path /self-hosted/*` guards on the generic rules, which cover every
	# /self-hosted/<slug> case order-independently.
	#
	# /self-hosted/<slug>.mdx (and the section landing /self-hosted.mdx) ->
	# /self-hosted/llms.mdx/<slug>/index.md. The optional group makes the landing
	# (no <slug>) collapse to /self-hosted/llms.mdx//index.md, which Caddy's path
	# cleaning normalizes to /self-hosted/llms.mdx/index.md.
	@shMdxAlias {
		path_regexp shmdxalias ^/self-hosted(?:/(.+))?\.mdx$
		not path /self-hosted/llms.mdx
		not path /self-hosted/llms.mdx/*
	}
	rewrite @shMdxAlias /self-hosted/llms.mdx/{re.shmdxalias.1}/index.md

	# Bare /self-hosted/llms.mdx -> /self-hosted/llms.mdx/index.md.
	@shLlmsMdxRoot path /self-hosted/llms.mdx
	rewrite @shLlmsMdxRoot /self-hosted/llms.mdx/index.md

	# /self-hosted/llms.mdx/<slug> needs the /index.md suffix appended.
	@shLlmsMdxSub {
		path /self-hosted/llms.mdx/*
		not path */index.md
	}
	rewrite @shLlmsMdxSub {http.request.uri.path}/index.md

	# Accept: text/markdown on a /self-hosted doc page -> its self-hosted twin.
	# `(.+?)/?$` captures the in-section slug and eats a trailing slash so the
	# rewrite lands on /self-hosted/llms.mdx/<slug>/index.md. Skips the machine
	# surfaces themselves (they serve their own content type).
	@shMarkdown {
		header_regexp Accept (?i)(^|,)\s*text/markdown
		path_regexp shmarkdown ^/self-hosted/(.+?)/?$
		not path /self-hosted/llms.mdx* /self-hosted/llms.txt /self-hosted/llms-full.txt
	}
	rewrite @shMarkdown /self-hosted/llms.mdx/{re.shmarkdown.1}/index.md
	# ── END llms twin rewrites (#4266) ───────────────────────────────────────

	# /<slug>.mdx -> /llms.mdx/<slug>/index.md (canonical markdown alias).
	# `not path /llms.mdx*` keeps the regex from re-matching the bare
	# /llms.mdx surface and the /llms.mdx/<slug> paths handled below.
	# `not path /self-hosted/*` keeps this root alias from grabbing the
	# /self-hosted twins handled by the #4266 block above.
	@mdxAlias {
		path_regexp mdxalias ^/(.+)\.mdx$
		not path /llms.mdx
		not path /llms.mdx/*
		not path /self-hosted/*
	}
	rewrite @mdxAlias /llms.mdx/{re.mdxalias.1}/index.md

	# Bare /llms.mdx -> /llms.mdx/index.md.
	@llmsMdxRoot path /llms.mdx
	rewrite @llmsMdxRoot /llms.mdx/index.md

	# The on-disk markdown emission always ends in /index.md, so every
	# browser-facing /llms.mdx/<slug> URL needs the suffix appended.
	@llmsMdxSub {
		path /llms.mdx/*
		not path */index.md
	}
	rewrite @llmsMdxSub {http.request.uri.path}/index.md

	# Accept: text/markdown content negotiation — rewrite docs-page URLs onto
	# their /llms.mdx/<slug>/index.md twin. Skip surfaces that already serve
	# their own content type (static assets, search index, well-known JSON,
	# the markdown surfaces themselves). `/self-hosted/*` is skipped here so the
	# #4266 block above handles /self-hosted/<slug> content-negotiation in-section
	# (its own twin, not the root's). The bare landing /self-hosted negotiates no
	# twin — its copy button uses the explicit /self-hosted.mdx via @shMdxAlias.
	@markdown {
		header_regexp Accept (?i)(^|,)\s*text/markdown
		not path /_next/* /api/* /.well-known/* /llms.mdx* /llms.txt /llms-full.txt /docs-og/* /favicon.ico /icon.svg /robots.txt /sitemap.xml /self-hosted/*
	}
	rewrite @markdown /llms.mdx{http.request.uri.path}/index.md

	# file_server serves <dir>/index.html for /<dir>/ and 301-redirects /<dir> -> /<dir>/,
	# matching Next.js trailingSlash: true. precompressed reads the .gz/.zst
	# sidecars produced by the Dockerfile so Caddy doesn't recompress per request.
	file_server {
		index index.html
		precompressed zstd gzip
	}

	# All error statuses fall back to the branded 404 shell. Caddy preserves
	# the original status code on the response, so a 502 keeps its 502 status
	# while presenting the styled body instead of Caddy's plain-text default.
	handle_errors {
		rewrite * /404.html
		file_server
	}

	# Per-request access logs were drowning real signal — every Googlebot
	# crawl hit a structured INFO line with full headers. ERROR-level keeps
	# Caddy startup / runtime errors visible; bump to INFO if you need to
	# debug a specific request path.
	log {
		output stdout
		format console
		level ERROR
	}
}

# === Atlas Internal Database ===
# Atlas's own Postgres for auth, audit logs, and settings.
# Auto-provisioned by most platforms. For local dev, docker compose provides it.
# DATABASE_URL=postgresql://atlas:atlas@localhost:5432/atlas

# === Analytics Datasource (your data) ===
# The database Atlas queries on your behalf. Optional — Atlas starts without it.
# ATLAS_DATASOURCE_URL=postgresql://atlas:atlas@localhost:5432/atlas_demo
# ATLAS_DATASOURCE_URL=mysql://user:pass@localhost:3306/mydb

# === LLM Provider (pick one) ===

# Vercel AI Gateway (recommended for Vercel deployments)
# Single API key for Claude, GPT, and other providers. See https://vercel.com/docs/ai-gateway
# ATLAS_PROVIDER=gateway
# AI_GATEWAY_API_KEY=...

# Direct provider (any deployment)
# ATLAS_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# ATLAS_PROVIDER=openai
# OPENAI_API_KEY=sk-...

# ATLAS_PROVIDER=bedrock
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...

# ATLAS_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434

# === Model (optional, provider-specific default used if omitted) ===
# ATLAS_MODEL=claude-opus-4-6

# === Authentication (optional — Atlas is public by default) ===
# ATLAS_API_KEY=your-secret-key            # Simple API key mode — requires Authorization: Bearer <key>
# BETTER_AUTH_SECRET=                      # Managed auth (Better Auth) — min 32 chars. Generate: openssl rand -base64 32
# BETTER_AUTH_URL=                         # Base URL for Better Auth (auto-detected from request if omitted)
# BETTER_AUTH_TRUSTED_ORIGINS=             # Comma-separated origins for CSRF (e.g. https://app.example.com)
# ATLAS_AUTH_JWKS_URL=                     # BYOT mode — JWKS endpoint URL
# ATLAS_AUTH_ISSUER=                       # BYOT mode — expected JWT issuer
# ATLAS_AUTH_AUDIENCE=                     # BYOT mode — expected JWT audience (optional)
# ATLAS_RATE_LIMIT_RPM=30                 # Max requests per minute per user (0 = disabled)

# === Security ===
# Non-SELECT SQL (INSERT, UPDATE, DELETE, DROP, etc.) is always rejected — no toggle.
# ATLAS_TABLE_WHITELIST=true   # Default: true — only allow tables in semantic layer
# ATLAS_ROW_LIMIT=1000         # Default: 1000
# ATLAS_QUERY_TIMEOUT=30000    # Default: 30s in milliseconds

# === Production Deployment ===
# Required for production (Railway, Render, etc.):
#   ATLAS_PROVIDER + its API key (e.g. ANTHROPIC_API_KEY)
#   ATLAS_DATASOURCE_URL=postgresql://user:pass@host:5432/dbname
#
# Optional (defaults are fine for most deployments):
#   ATLAS_MODEL, ATLAS_ROW_LIMIT, ATLAS_QUERY_TIMEOUT
#   PORT (set automatically by most platforms)

# === Explore Tool Isolation ===
# @vercel/sandbox is auto-detected on Vercel (no configuration needed).
# ATLAS_RUNTIME=vercel    # Override for local dev — on Vercel this is auto-detected via the VERCEL env var

# === Scheduled Tasks (Vercel Cron) ===
# ATLAS_SCHEDULER_ENABLED=true
# ATLAS_SCHEDULER_BACKEND=vercel
# CRON_SECRET=...          # Set in Vercel dashboard → Settings → Environment Variables

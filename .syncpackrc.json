{
  "source": [
    "package.json",
    "packages/*/package.json",
    "apps/*/package.json",
    "examples/nextjs-standalone/package.json",
    "plugins/*/package.json",
    "create-atlas/templates/*/package.json",
    "create-atlas-plugin/package.json"
  ],
  "versionGroups": [
    {
      "label": "Workspace packages use workspace: protocol",
      "dependencies": ["@atlas/**", "@useatlas/**"],
      "dependencyTypes": ["prod", "dev"],
      "pinVersion": "workspace:*"
    },
    {
      "label": "Published packages use wide peer dep ranges for compatibility",
      "packages": [
        "@useatlas/react",
        "@useatlas/plugin-sdk",
        "@useatlas/clickhouse",
        "@useatlas/snowflake",
        "@useatlas/duckdb",
        "@useatlas/mysql",
        "@useatlas/salesforce",
        "@useatlas/e2b",
        "@useatlas/daytona",
        "@useatlas/nsjail",
        "@useatlas/sidecar",
        "@useatlas/vercel-sandbox",
        "@useatlas/slack",
        "@useatlas/mcp",
        "@useatlas/email",
        "@useatlas/jira",
        "@useatlas/yaml-context",
        "@useatlas/create-plugin"
      ],
      "dependencyTypes": ["peer"],
      "isIgnored": true
    },
    {
      "label": "Templates and examples use loose ranges for framework deps",
      "dependencies": ["react", "react-dom", "better-auth"],
      "packages": [
        "%PROJECT_NAME%",
        "@atlas/web",
        "@atlas/nextjs-standalone",
        "@atlas/www"
      ],
      "isIgnored": true
    }
  ]
}

# Refuse to execute package install scripts (preinstall, install, postinstall).
# Bun ignores lifecycle scripts by default for anything not in trustedDependencies,
# but this protects the npm-touching surfaces:
#   - Scaffold CI workflows running `npm install` against create-atlas templates
#   - examples/* (Docker, nextjs-standalone) when consumers use npm
#   - Plugin installs via `npm install <plugin>`
# When a native build legitimately needs scripts (sharp, better-sqlite3, etc.),
# run that one install with `--ignore-scripts=false`.
ignore-scripts=true

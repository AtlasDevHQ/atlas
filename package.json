{
  "name": "atlas",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "description": "Deploy-anywhere text-to-SQL agent with auto-generated semantic layer and production-grade security",
  "workspaces": [
    "packages/*",
    "apps/*",
    "examples/nextjs-standalone",
    "examples/embedded-mcp-onboarding",
    "plugins/*",
    "create-atlas-plugin",
    "ee"
  ],
  "scripts": {
    "dev": "bash scripts/db-up.sh && bun run --hot packages/api/src/api/server.ts & API_PID=$!; trap 'kill $API_PID 2>/dev/null' EXIT; bun run --filter '@atlas/web' dev",
    "dev:api": "bun run --hot packages/api/src/api/server.ts",
    "dev:web": "bun run --filter '@atlas/web' dev",
    "dev:www": "bun run --filter '@atlas/www' dev",
    "dev:docs": "bun run --filter '@atlas/docs' dev",
    "dev:mcp": "bun run --filter '@atlas/mcp' dev",
    "build": "bun run --filter '@atlas/web' build",
    "build:www": "bun run --filter '@atlas/www' build",
    "build:docs": "bun run --filter '@atlas/docs' build",
    "start": "sh scripts/start.sh",
    "lint": "oxlint --config .oxlintrc.json packages/ ee/ plugins/ apps/ examples/ create-atlas/",
    "type": "bun run --filter '@useatlas/types' build && bun run --filter '@useatlas/plugin-sdk' build && bun run --filter '@useatlas/sdk' build && bun run --filter '@useatlas/react' build && tsgo --noEmit && bun run --filter '@atlas/web' type && bun run --filter '@atlas/www' type",
    "atlas": "bun packages/cli/bin/atlas.ts",
    "atlas-operator": "bun packages/cli/bin/atlas-operator.ts",
    "mcp": "bun packages/mcp/bin/serve.ts",
    "db:up": "bash scripts/db-up.sh",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && bash scripts/db-up.sh",
    "db:nuke": "bash scripts/db-nuke.sh",
    "db:multi-env:up": "docker compose -f docker-compose.yml -f docker-compose.multi-env.yml up -d pg-dev pg-staging pg-prod",
    "db:multi-env:down": "docker compose -f docker-compose.multi-env.yml down",
    "db:multi-env:reset": "docker compose -f docker-compose.multi-env.yml down -v && docker compose -f docker-compose.yml -f docker-compose.multi-env.yml up -d pg-dev pg-staging pg-prod",
    "db:multi-env:seed": "bun scripts/seed-multi-env.ts",
    "test": "bun run test:api && bun run test:others",
    "test:api": "bun run --filter '@atlas/api' test",
    "test:others": "bun run scripts/test-others.ts",
    "test:e2e": "bash e2e/scripts/run.sh",
    "test:e2e:core": "bash e2e/scripts/run.sh --tier core",
    "test:e2e:query": "bash e2e/scripts/run.sh --tier query",
    "test:e2e:scaffold": "bash e2e/scripts/run.sh --tier scaffold",
    "test:e2e:all": "bash e2e/scripts/run.sh --all",
    "test:e2e:docker": "bash e2e/scripts/run.sh --tier docker",
    "test:e2e:integration": "bash e2e/scripts/run.sh --tier integration",
    "eval:canonical": "bun packages/cli/bin/atlas.ts canonical-eval",
    "smoke": "bash scripts/smoke.sh",
    "smoke:scaffold": "bash create-atlas/smoke-test.sh",
    "smoke:remote": "bun run atlas -- smoke",
    "test:browser": "bun x playwright test --config e2e/browser/playwright.config.ts",
    "test:browser:fast": "bun x playwright test --config e2e/browser/playwright.config.ts --grep-invert @llm",
    "test:browser:llm": "bun x playwright test --config e2e/browser/playwright.config.ts --grep @llm --workers 1",
    "test:browser:prod": "bun x playwright test --config e2e/browser/playwright.config.ts --project production",
    "deps:lint": "bun x syncpack lint",
    "deps:fix": "bun x syncpack fix",
    "deps:update": "bun update && bun x syncpack fix"
  },
  "engines": {
    "node": ">=20.9.0",
    "bun": ">=1.3.13 <1.3.14"
  },
  "homepage": "https://www.useatlas.dev",
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@playwright/test": "^1.60.0",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.4",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.15",
    "@typescript/native-preview": "^7.0.0-dev.20260623.1",
    "@vercel/og": "0.11.1",
    "jose": "^6.2.3",
    "oxlint": "^1.72.0",
    "oxlint-plugin-eslint": "^1.72.0",
    "pg": "^8.22.0",
    "react": "^19.2.6",
    "syncpack": "^15.3.2",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "^4.0.119",
    "@ai-sdk/anthropic": "^3.0.85",
    "@ai-sdk/gateway": "^3.0.133",
    "@ai-sdk/openai": "^3.0.74",
    "@ai-sdk/provider": "^3.0.10",
    "@ai-sdk/react": "^3.0.210",
    "@aws-sdk/client-bedrock": "^3.1075.0",
    "@better-auth/api-key": "^1.6.20",
    "@better-auth/oauth-provider": "^1.6.20",
    "@better-auth/passkey": "^1.6.20",
    "@better-auth/scim": "^1.6.20",
    "@better-auth/stripe": "^1.6.20",
    "@clack/prompts": "^1.6.0",
    "@clickhouse/client": "^1.22.0",
    "@effect/ai": "^0.36.0",
    "@effect/ai-anthropic": "^0.26.0",
    "@effect/ai-openai": "^0.39.2",
    "@effect/platform": "^0.96.2",
    "@effect/sql": "^0.51.1",
    "@hono/zod-openapi": "^1.4.0",
    "@hookform/resolvers": "^5.4.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.218.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-metrics": "^2.8.0",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@radix-ui/react-slot": "^1.3.0",
    "@shikijs/transformers": "^4.2.0",
    "@tailwindcss/cli": "^4.3.1",
    "@tailwindcss/postcss": "^4.3.1",
    "@tanstack/react-query": "^5.101.1",
    "@tanstack/react-query-devtools": "^5.101.1",
    "@types/nodemailer": "^8.0.1",
    "ai": "^6.0.208",
    "better-auth": "^1.6.20",
    "date-fns": "^4.4.0",
    "effect": "^3.21.4",
    "fumadocs-core": "~16.9.3",
    "fumadocs-openapi": "^10.9.1",
    "fumadocs-ui": "~16.9.3",
    "happy-dom": "^20.10.6",
    "hono": "^4.12.27",
    "ipaddr.js": "^2.4.0",
    "js-yaml": "^5.1.0",
    "jsforce": "^3.10.16",
    "lucide-react": "^1.21.0",
    "mysql2": "^3.22.4",
    "nanoid": "^5.1.15",
    "next": "^16.2.9",
    "nodemailer": "^9.0.1",
    "obsidian": "^1.13.1",
    "radix-ui": "^1.6.0",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.80.0",
    "react-resizable-panels": "^4",
    "snowflake-sdk": "^2.4.3",
    "tailwindcss": "^4.3.1",
    "zustand": "^5.0.14"
  }
}

{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "deploy/docs/Dockerfile",
    "dockerfileContext": "../..",
    "watchPatterns": [
      "bun.lock",
      "brand.css",
      "apps/docs/**",
      "deploy/docs/**"
    ]
  },
  "deploy": {
    "healthcheckPath": "/",
    "healthcheckTimeout": 60,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}

# Atlas environment variables. This file is the SELF-HOST reference — it covers
# the common single-region, self-hosted setup. Every variable (defaults,
# precedence, per-section detail) is documented at:
#   https://docs.useatlas.dev/reference/environment-variables
# All commented (#) vars below are optional — uncomment only the ones you need.
#
# ─────────────────────────────────────────────────────────────────────────────
# Running Atlas as a hosted SaaS region? You do NOT need most of this file.
# A hosted region needs only the ~21-var SaaS boot floor — the single source of
# truth is SAAS_ENV_KEYS in packages/api/src/lib/effect/saas-env.ts, and the
# operator-facing, auto-generated reference is:
#   https://docs.useatlas.dev/platform-ops/saas-environment-variables
# On SaaS, env is for secrets + pre-database boot inputs only; everything else
# (limits, providers, integrations, branding) is a runtime Admin-console setting.
# The rest of this file is optional self-host knobs.
# ─────────────────────────────────────────────────────────────────────────────

# === Configuration ===
# Atlas supports two configuration modes:
#
# 1. Environment variables (this file) — simple, single-datasource deploys.
# 2. atlas.config.ts — declarative, multi-datasource deploys.
#
# When atlas.config.ts exists in the project root, it takes precedence for
# datasources and tool configuration. Auth and other settings still use env vars.
# See docs/hono-extraction-design.md (Phase 6) for details.
#
# Example atlas.config.ts:
#   import { defineConfig } from "@atlas/api/lib/config";
#   export default defineConfig({
#     datasources: {
#       default: { url: process.env.ATLAS_DATASOURCE_URL! },
#       warehouse: { url: "postgresql://...", schema: "analytics" },
#     },
#     tools: ["explore", "executeSQL"],
#     auth: "auto",
#     semanticLayer: "./semantic",
#   });

# === Atlas Internal Database ===
# Atlas's own Postgres for auth, audit logs, and settings.
# Pre-configured for local Docker Postgres (bun run db:up).
DATABASE_URL=postgresql://atlas:atlas@localhost:5432/atlas
# DATABASE_URL_UNPOOLED=                      # Unpooled Postgres URL (e.g. a Neon direct connection). When
#                                             # ATLAS_DEMO_DATA=true and ATLAS_DATASOURCE_URL is unset, this is
#                                             # checked BEFORE DATABASE_URL in the demo-data fallback chain.
# SaaS multi-region only: ATLAS_REGION_US_DB_URL / ATLAS_REGION_EU_DB_URL / ATLAS_REGION_APAC_DB_URL are
# part of the SaaS boot contract (SAAS_ENV_KEYS in packages/api/src/lib/effect/saas-env.ts) — the per-region
# internal Postgres URLs the data-residency router targets. Self-hosted single-region deploys use DATABASE_URL
# only and never set these. Full operator reference: docs/platform-ops/saas-environment-variables.

# === Analytics Datasource (your data) ===
# The database Atlas queries on your behalf.
# Pre-configured for the demo dataset seeded by `bun run db:up`.
# When atlas.config.ts defines datasources, this env var is not needed.
ATLAS_DATASOURCE_URL=postgresql://atlas:atlas@localhost:5432/atlas_demo
# ATLAS_DATASOURCE_URL=mysql://user:pass@localhost:3306/mydb
# ATLAS_DATASOURCE_URL=elasticsearch://my-cluster.es.io:9243   # Elasticsearch (HTTPS; append ?ssl=false for a local cluster). opensearch://host:9200 selects the OpenSearch engine
# ATLAS_ES_CLOUD_ID=                           # Elastic Cloud ID (<name>:<base64>) — endpoint alternative to the elasticsearch:// URL above
# Elasticsearch auth for `atlas init`/`diff` — pick ONE mode; credentials are NOT carried in the URL (precedence: SigV4 → Basic → API key):
# ATLAS_ES_API_KEY=                            # Base64 API key
# ATLAS_ES_USERNAME=                           # HTTP Basic username (requires ATLAS_ES_PASSWORD)
# ATLAS_ES_PASSWORD=                           # HTTP Basic password (requires ATLAS_ES_USERNAME)
# ATLAS_ES_AWS_REGION=                         # Selects AWS SigV4 (Amazon OpenSearch Service); keys from AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY (+ AWS_SESSION_TOKEN)
# ATLAS_ES_AWS_SERVICE=                        # SigV4 service code (default "es"; "aoss" for OpenSearch Serverless)
# ATLAS_ES_ENGINE=                             # Optional engine override: elasticsearch | opensearch (wins over the URL scheme)
# NOTE: ATLAS_ES_API_KEY is the canonical name. The atlas.config.ts examples wire the same var into the
# plugin's `apiKey:` field (elasticsearchPlugin({ apiKey: process.env.ATLAS_ES_API_KEY! })), so one
# variable covers BOTH the CLI auto-read path (above) and an explicit static config.

# === LLM Provider (pick one) ===
# ATLAS_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# ATLAS_PROVIDER=openai
# OPENAI_API_KEY=sk-...

# ATLAS_PROVIDER=bedrock
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_SESSION_TOKEN=...                 # Optional — temporary (STS) credentials only. Also read by the Elasticsearch AWS SigV4 path (ATLAS_ES_AWS_REGION)

# ATLAS_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434

# ATLAS_PROVIDER=openai-compatible
# ATLAS_MODEL=llama3.1
# OPENAI_COMPATIBLE_BASE_URL=http://localhost:8000/v1
# OPENAI_COMPATIBLE_API_KEY=            # Optional — most local servers don't need one

# ATLAS_PROVIDER=gateway
# AI_GATEWAY_API_KEY=...
# ATLAS_GATEWAY_CATALOG_TTL_MS=               # TTL (ms) for the cached Vercel AI Gateway model catalog (gateway
#                                             # provider). Mirrors ATLAS_BYOT_CATALOG_TTL_MS but for the gateway.
#                                             # Default: gateway default.

# === Model (optional, provider-specific default used if omitted) ===
# Leave unset to use the provider default — gateway → anthropic/claude-sonnet-4.6,
# anthropic → claude-opus-4-8 (see packages/api/src/lib/providers.ts).
# ATLAS_MODEL=anthropic/claude-sonnet-4.6

# === Authentication ===
# Managed auth is enabled by default for local dev.
# On first boot, a dev admin account is seeded: admin@useatlas.dev / atlas-dev
# Generate your own secret for production: openssl rand -base64 32
BETTER_AUTH_SECRET=atlas-dev-secret-do-not-use-in-production!!
BETTER_AUTH_URL=http://localhost:3001
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3000
#
# ATLAS_ADMIN_EMAIL — REQUIRED for managed auth in production.
# When set, the user signing up with this exact email is promoted to
# platform_admin on creation. All other signups become regular members.
# Leave unset only for CI / ephemeral demos that also set
# ATLAS_ALLOW_FIRST_SIGNUP_ADMIN=true (see below).
ATLAS_ADMIN_EMAIL=admin@useatlas.dev
#
# ATLAS_ALLOW_FIRST_SIGNUP_ADMIN=true       # Opt-in fallback: when ATLAS_ADMIN_EMAIL is unset AND no admin user exists, promote the
                                            # first signup to platform_admin. DO NOT use in production — any unauthenticated visitor
                                            # could race the operator and claim platform_admin with a single signup request.
#
# ATLAS_AUTH_MODE=                          # Force auth mode: managed | api-key | byot | none (auto-detected by default)
#
# Other auth modes (uncomment one to switch):
# ATLAS_API_KEY=your-secret-key            # Simple API key mode — requires Authorization: Bearer <key>
# ATLAS_AUTH_JWKS_URL=                     # BYOT mode — JWKS endpoint URL
# ATLAS_AUTH_ISSUER=                       # BYOT mode — expected JWT issuer
# ATLAS_AUTH_AUDIENCE=                     # BYOT mode — expected JWT audience (optional)
# ATLAS_AUTH_ROLE_CLAIM=role              # JWT claim path for BYOT role extraction (supports nested: app_metadata.role)
# ATLAS_API_KEY_ROLE=admin                # Role for simple-key auth (member/admin/owner). Default: admin; invalid values fall back to admin
# ATLAS_RATE_LIMIT_RPM=30                 # Max requests per minute per user (0/empty = disabled). Default: from
#                                         # ATLAS_DEPLOY_ENV profile (prod/dev: disabled, staging: 300). A platform-level
#                                         # DB override and this env var both win over the profile default.
#                                         # SaaS (ATLAS_DEPLOY_MODE=saas): MUST be a positive integer (>= 1) — the API
#                                         # REFUSES TO BOOT (RateLimitGuardLive → RateLimitRequiredError, #1983) when this
#                                         # is unset, empty, or < 1, so a region can't silently run with the limiter off.
#                                         # Self-hosted: unset = unlimited (fine for trials / single-tenant).
# ATLAS_RATE_LIMIT_RPM_CHAT=               # Chat-stream RPM ceiling, separate bucket from cheap reads (F-74).
#                                         # Defaults to max(5, RPM/4) so a 25-step LLM call does not deplete
#                                         # the same allowance that serves audit-log scrolling and similar
#                                         # cheap reads. Disabled when ATLAS_RATE_LIMIT_RPM is 0.
# ATLAS_RATE_LIMIT_RPM_ADMIN=              # Admin namespace RPM ceiling, separate bucket from cheap reads
#                                         # (#2485). Defaults to max(60, RPM) so an interactive admin
#                                         # session (DELETE + Test + Add Connection) does not throttle
#                                         # on a low base RPM tuned for public traffic.
#                                         # Disabled when ATLAS_RATE_LIMIT_RPM is 0.
# ATLAS_TRUST_PROXY=false                 # Trust X-Forwarded-For for client IP (set "true" behind a reverse proxy).
#                                         # Public-share routes bucket all anonymous (no-IP) requests into a
#                                         # single 10/min ceiling when this is unset (F-73).
#
# === Better Auth hardening (managed auth only) ===
# ATLAS_REQUIRE_EMAIL_VERIFICATION=true   # Require email verification on signup. Default: from ATLAS_DEPLOY_ENV profile (prod: true, staging/dev: false).
#                                         # Setting "false" re-enables the signup USER_ALREADY_EXISTS error
#                                         # (email enumeration oracle) — only acceptable for self-hosted
#                                         # single-tenant deployments without an email provider.
# ATLAS_AUTH_RATE_LIMIT_ENABLED=true      # Rate limit /api/auth/* endpoints. Default: true.
# ATLAS_AUTH_RATE_LIMIT_WINDOW=60         # Global rate-limit window (seconds). Default: 60.
# ATLAS_AUTH_RATE_LIMIT_MAX=100           # Global rate-limit ceiling. Per-endpoint rules are tighter
#                                         # (signin ≤10/min, signup/forget ≤5/min) — those are not
#                                         # overridable via env by design.
# ATLAS_MFA_ISSUER=Atlas                  # Issuer label shown in TOTP authenticator apps when users
#                                         # enroll an MFA device. Default: "Atlas".
# ATLAS_RPID=app.useatlas.dev             # WebAuthn Relying Party ID — the registrable domain passkeys are
#                                         # bound to. When UNSET, it is derived from the configured web origin's
#                                         # host (first ATLAS_CORS_ORIGIN entry, then BETTER_AUTH_TRUSTED_ORIGINS,
#                                         # then the region-derived web origin — ATLAS_API_REGION + residency.regions[].apiUrl,
#                                         # api host label swapped to app, #3706): prod → app.useatlas.dev,
#                                         # staging → app.staging.useatlas.dev, localhost → localhost.
#                                         # If no web origin is configured, falls back to app.useatlas.dev.
#                                         # Boot FAILS LOUD if the effective rpID isn't valid for the web origin
#                                         # (must equal the origin host or be a parent domain) — no silent browser breakage.
#                                         # SaaS multi-region: no longer stamped per service — the region
#                                         # derivation yields the same app.useatlas.dev for every prod region.
#                                         # Pin it explicitly only if a CORS-origin reorder could shift the
#                                         # derived value. Self-hosted on a custom
#                                         # domain: set to your auth domain. Changing this AFTER passkeys are
#                                         # enrolled invalidates every enrolled passkey.
# ATLAS_RPNAME=Atlas                      # Human-readable string the OS shows in the passkey prompt
#                                         # ("Use your saved passkey for <ATLAS_RPNAME>?"). Default: "Atlas".
# ATLAS_ABUSE_QUERY_RATE=200              # Max queries per workspace per sliding window (abuse prevention)
# ATLAS_ABUSE_WINDOW_SECONDS=300          # Sliding window duration in seconds
# ATLAS_ABUSE_ERROR_RATE=0.5              # Max error rate (0-1) before escalation
# ATLAS_ABUSE_UNIQUE_TABLES=50            # Max unique tables accessed per window
# ATLAS_ABUSE_THROTTLE_DELAY_MS=2000      # Delay injected for throttled workspaces (ms)
# ATLAS_ABUSE_ESCALATION_COOLDOWN_SECONDS=60
#                                         # Min dwell time at each level before next escalation rung fires.
#                                         # Stops a single failing-query burst from walking warning→throttled→suspended in seconds.
#                                         # Abuse detection only runs when ATLAS_DEPLOY_MODE=saas; self-hosted skips it entirely.
# ATLAS_LOADTEST_ALLOWED_ORGS=            # Comma-separated workspace IDs designated for load testing. Listed
#                                         # workspaces may mint MCP load-test JWTs (POST /api/v1/me/load-test/mcp-token)
#                                         # AND bypass abuse-prevention escalation, so a load run can't auto-suspend
#                                         # the workspace it targets. Operator escape hatch — not a threshold substitute.
# ATLAS_SESSION_IDLE_TIMEOUT=0            # Seconds of inactivity before session invalidation (0 = disabled)
# ATLAS_SESSION_ABSOLUTE_TIMEOUT=0        # Max session lifetime in seconds (0 = disabled)
# ATLAS_SESSION_COOKIE_CACHE_MAX_AGE_SEC=30
#                                         # Max age (seconds) of Better Auth's signed session cookie cache.
#                                         # Bounds the window between banUser()/revokeSession() and the
#                                         # user actually being kicked out of authenticated routes
#                                         # (F-07). Default 30s, clamped to [5, 300]. Lower = faster
#                                         # revocation, slightly more DB reads per session.
# ATLAS_SEMANTIC_ROOT=                    # Dev/test override for semantic layer directory (production: use atlas.config.ts semanticLayer)
# ATLAS_SEMANTIC_INDEX_ENABLED=true       # Pre-computed semantic index in agent prompt (default: true)

# === Social Login (optional, managed auth only) ===
# Uncomment a provider block to enable social sign-in alongside email/password.
# Also add the corresponding socialProviders config to betterAuth() in server.ts.
# See: docs/guides/social-providers
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# MICROSOFT_TENANT_ID=common              # common | organizations | consumers | <tenant-uuid>

# === MCP transport ===
# ATLAS_MCP_USER_ID=                        # MCP actor binding — Atlas user id (#1858).
# ATLAS_MCP_ORG_ID=                         # MCP actor binding — org id the bound user acts under.
#                                           # Set BOTH for governed transport (approval rules + audit
#                                           # apply to MCP queries). Leave BOTH unset for trusted
#                                           # transport (synthetic system:mcp actor; only safe when
#                                           # no approval rules exist). MCP fails to boot if rules
#                                           # exist and the binding is missing — see docs/guides/mcp.
# ATLAS_MCP_RATE_LIMIT_FAIL_CLOSED=false    # When "true", an MCP rate-limit-store outage (Redis / internal DB
#                                           # unreachable) REJECTS requests instead of letting them through. SaaS
#                                           # opts in; self-hosted defaults to fail-open. Default: false.
# ATLAS_MCP_RATE_LIMIT_MAX_KEYS=10000       # Max distinct MCP rate-limit keys retained per workspace before LRU
#                                           # eviction (bounds memory on many short-lived OAuth clients). Default
#                                           # 10000; clamped to a minimum of 100.
# ATLAS_MCP_MAX_SESSIONS=100                # Hosted (SSE / Streamable HTTP) concurrent-session cap. A positive
#                                           # integer overrides the deploy-env profile default (100); it bounds the
#                                           # in-memory session map, and connections past the cap get 503 until an
#                                           # idle session is swept. Non-positive / malformed → profile default.
# ATLAS_MCP_SESSION_IDLE_TIMEOUT_MS=1800000 # Hosted idle-session reap threshold (ms). A session whose last activity
#                                           # is older than this is closed under cap-pressure so vanished clients
#                                           # (closed laptop, killed app) don't permanently exhaust the pool.
#                                           # Default 1800000 (30m); floor 60000 (1m) — below floor / missing /
#                                           # malformed falls back to the default.
# ATLAS_MCP_MAX_HELD_STREAM_AGE_MS=7200000  # Hosted: max age (ms) a GET stream may stay open before the sweep
#                                           # reclaims its session under cap-pressure (packages/mcp/src/session-store.ts).
#                                           # Default 7200000 (2h); no floor — set 0 to disable age-based reclaim.
#                                           # Negative/malformed falls back to the default.
# ATLAS_CANONICAL_QUESTIONS_PATH=           # Override path to the canonical-questions YAML backing the canonical
#                                           # MCP prompts (eval harness #2025). Defaults to
#                                           # eval/canonical-questions/questions.yml resolved from the repo root.
#                                           # Setting it to an empty string is rejected (refuses rather than
#                                           # silently masking an env-template error).

# === OAuth Provider (MCP / DCR) ===
# Atlas issues OAuth 2.1 tokens via @better-auth/oauth-provider so MCP clients
# (Claude Desktop, ChatGPT, Cursor) connect to the hosted MCP endpoint via
# Dynamic Client Registration + PKCE. Most operators leave these on defaults.
# ATLAS_OAUTH_VALID_AUDIENCES=             # Comma-separated allowed JWT `aud` values. Default: derived from ATLAS_PUBLIC_API_URL/BETTER_AUTH_URL (<base>/mcp)
# ATLAS_OAUTH_ALLOW_UNAUTH_DCR=true        # Allow unauthenticated public client registration (RFC 7591). Set false for stricter threat models
# ATLAS_OAUTH_ACCESS_TOKEN_TTL_SECONDS=3600       # Access-token lifetime. Default: 3600 (1h). Empty/non-numeric/≤0 falls back to default
# ATLAS_OAUTH_REFRESH_TOKEN_TTL_SECONDS=2592000   # Refresh-token lifetime. Default: 2592000 (30d). Same parse rules as access TTL
# ATLAS_OAUTH_STATE_TTL_SECONDS=600        # TTL for OAuth state tokens during integration install flows. Default: 600 (10m), clamped [60, 3600]

# === Agent ===
# ATLAS_AGENT_MAX_STEPS=25     # Default: 25, range 1–100. Max tool-call steps per agent run
# ATLAS_BYOT_CATALOG_TTL_MS=21600000        # Default 6h. Server-side TTL for the per-workspace BYOT
#                                           # provider catalog (Anthropic /v1/models — #2271). Discovery
#                                           # hits upstream when the workspace's cache entry has
#                                           # expired or admin clicks "Refresh now" on AI Provider.
# ATLAS_BYOT_DORMANCY_DAYS=30               # Default 30. The scheduled BYOT catalog refresh skips
#                                           # workspaces idle longer than this many days (no chat
#                                           # activity), sparing provider rate-limits + audit noise on
#                                           # catalogs nobody sees (#2377). Managed-auth only. Set 0 to
#                                           # disable the gate (refresh every configured workspace).
# ATLAS_CONVERSATION_STEP_CAP=500           # Aggregate step ceiling per conversation (F-77).
#                                           # Default 500 = 20 follow-ups × 25 steps. Once total_steps
#                                           # crosses this value the chat handler returns 429
#                                           # `conversation_budget_exceeded` and the UI offers to start
#                                           # a new conversation. Set 0 to disable.
# ATLAS_DASHBOARD_DRAFTS_ENABLED=true       # Default: true (flipped ON in #2521 alongside the Publish UI).
#                                           # When ON, every dashboard edit via chat ("Edit with chat")
#                                           # lands on a per-user draft instead of writing straight to
#                                           # the published dashboard. Users hit Publish to merge the
#                                           # draft into the live row. Set EXACTLY "false" (lower-case)
#                                           # to opt out and restore the pre-#2364 last-write-wins
#                                           # behavior. The strict-string match means typos ("0" / "no"
#                                           # / "FALSE") leave drafts enabled — fail-closed for safety.

# ATLAS_DASHBOARD_EXPORT_TIMEOUT_MS=60000   # Default: 60000 (60s). Overall wall-clock budget for a headless dashboard
#                                           # PDF/PNG export (lib/dashboard-screenshot.ts). Clamped to [5000, 180000];
#                                           # a lower value degrades to a documented PARTIAL capture, not a 504.

# === Semantic Expert ===
# ATLAS_EXPERT_SCHEDULER_ENABLED=false    # Enable periodic semantic layer analysis
# ATLAS_EXPERT_SCHEDULER_INTERVAL_HOURS=24  # Hours between scheduled runs
# ATLAS_EXPERT_AUTO_APPROVE_THRESHOLD=     # Auto-approve threshold (e.g. 0.9). Empty = disabled
# ATLAS_EXPERT_AUTO_APPROVE_TYPES=update_description,add_dimension  # Amendment types eligible for auto-approval

# === Security ===
# Non-SELECT SQL (INSERT, UPDATE, DELETE, DROP, etc.) is always rejected — no toggle.
# ATLAS_TABLE_WHITELIST=true   # Default: true — only allow tables in semantic layer
# ATLAS_ROW_LIMIT=1000         # Default: 1000
# ATLAS_QUERY_TIMEOUT=30000    # Default: 30s in milliseconds
# ATLAS_DELIVERY_MAX_ROWS=50   # Default: 50, range 1–10000. Max rows per dataset in scheduled-delivery reports
# ATLAS_SCHEMA=                # PostgreSQL schema for profiling and runtime queries. When set to a non-public value, sets search_path. No default — PostgreSQL uses its server default when unset

# ATLAS_POOL_WARMUP=2           # Default: 2 — warmup probes per connection at startup (0 = disabled)
# ATLAS_POOL_DRAIN_THRESHOLD=5  # Default: 5 — consecutive query errors before pool drain/recreate
# ATLAS_ORG_WHITELIST_TTL_MS=60000  # Default: 60000 (60s) — TTL for the per-org semantic-layer table-whitelist cache. Longer = fewer semantic scans, slower visibility of newly-added entities. Invalid/<=0 falls back to 60s

# === Row-Level Security (optional) ===
# ATLAS_RLS_ENABLED=false                     # Enable RLS — injects WHERE clause filtering based on JWT claims
# ATLAS_RLS_COLUMN=                           # Column to filter on (e.g. tenant_id, org_id)
# ATLAS_RLS_CLAIM=                            # JWT claim path to extract value (e.g. org_id, app_metadata.tenant)
# ATLAS_RLS_CLAIMS='{"tenant_id":"acme-corp"}'  # Static JSON-object claims for RLS under simple-key (ATLAS_API_KEY) auth,
#                                             # where there's no JWT/session to extract from. Distinct from ATLAS_RLS_CLAIM
#                                             # above (a claim PATH). Invalid / non-object JSON is ignored with a warn.

# === Query Cache ===
# ATLAS_CACHE_ENABLED=true     # Default: true — enable query result caching
# ATLAS_CACHE_TTL=300000       # Default: 300000 (5 minutes) — cache TTL in milliseconds
# ATLAS_CACHE_MAX_SIZE=1000    # Default: 1000 — max cached query results (LRU eviction)

# === Dynamic Learning ===
# ATLAS_LEARN_CONFIDENCE_THRESHOLD=0.7   # Default: 0.7 — min confidence (0-1) for auto-promoting learned patterns
# ATLAS_LEARN_RETRIEVAL_TURNS=3          # Default: 3 — trailing user turns assembled into the learned-pattern retrieval query
# ATLAS_LEARN_PROMOTE_DECAY_ENABLED=false        # Default: false — enable the nightly job (#3636) that auto-promotes high-confidence, fast, frequently-seen learned patterns and demotes stale auto-promoted ones (human approvals are never demoted). Platform-scoped; requires restart. Also runtime-controllable in Admin → Settings
# ATLAS_LEARN_PROMOTE_DECAY_INTERVAL_HOURS=24    # Default: 24 — hours between auto-promote/decay runs. Platform-scoped; requires restart

# === Starter Prompts ===
# ATLAS_STARTER_PROMPT_COLD_WINDOW_DAYS=90     # Default: 90 — window (days) on prompt_collections.created_at for the adaptive starter-prompt resolver and the auto-promote eligibility window
# ATLAS_STARTER_PROMPT_AUTO_PROMOTE_CLICKS=3   # Default: 3 — distinct-user click threshold that auto-promotes a learned suggestion into the admin approval queue
# ATLAS_STARTER_PROMPT_MAX_FAVORITES=10        # Default: 10 — hard cap on per-user pinned starter prompts

# === Demo Data ===
# ATLAS_DEMO_DATA=true         # Use internal DB as both analytics datasource and internal DB

# === Demo Mode (email-gated public demo) ===
# ATLAS_DEMO_ENABLED=false               # Enable demo mode at /demo (requires BETTER_AUTH_SECRET for token signing)
# ATLAS_DEMO_RATE_LIMIT_RPM=10           # Max requests per minute per demo user (default: 10)
# ATLAS_DEMO_MAX_STEPS=10                # Max agent steps per demo request (default: 10)
# ATLAS_DEMO_INDUSTRY=                   # Industry for the seeded __demo__ connection (e.g. cybersecurity, ecommerce). Set at signup via onboarding — drives prompt-library filtering + publish archival cascade

# === Encryption ===
# ATLAS_ENCRYPTION_KEYS=v1:PRIMARY-KEY[,v2:NEW-KEY]  # F-47: comma-separated versioned keyset. First entry is the active write key; later entries are legacy read-only keys kept for the rotation soak. Use during rotation — see docs/platform-ops/encryption-key-rotation.
# ATLAS_ENCRYPTION_KEY=        # Legacy single-key form (kept for back-compat). Treated as an implicit v1 when ATLAS_ENCRYPTION_KEYS is not set. Takes precedence over BETTER_AUTH_SECRET.
# BETTER_AUTH_SECRET is used as the at-rest encryption key when no dedicated key is set. Self-hosted deploys may rely on this; SaaS deploys (ATLAS_DEPLOY_MODE=saas) should set ATLAS_ENCRYPTION_KEYS to a dedicated value — Atlas logs a deprecation warning otherwise.
# ATLAS_STRICT_PLUGIN_SECRETS=false  # F-42 #1835: when "true", the plugin admin write paths reject PUTs whose catalog schema is corrupt or carries per-key secret/passthrough drift. SaaS regions opt in; self-hosted defaults to off. Tolerant idempotent passthrough is the baseline.

# === Email ===
# ATLAS_EMAIL_PROVIDER=resend                     # Platform email provider: resend | sendgrid | postmark | smtp | ses (default: resend). Primarily set via Admin > Settings
# RESEND_API_KEY=                                 # Resend API key for email delivery (scheduled tasks + onboarding)
# SENDGRID_API_KEY=                               # SendGrid API key (used when ATLAS_EMAIL_PROVIDER=sendgrid)
# POSTMARK_SERVER_TOKEN=                          # Postmark server token (used when ATLAS_EMAIL_PROVIDER=postmark)
# ATLAS_EMAIL_ALLOWED_DOMAINS=                    # Comma-separated allowed recipient domains for email actions (unset = all allowed)
# ATLAS_EMAIL_FROM=Atlas <noreply@useatlas.dev>   # From address for scheduled task and action emails
# ATLAS_SMTP_URL=                                 # Webhook URL for email delivery (POST JSON with from/to/subject/html) — alternative to Resend
# ATLAS_ONBOARDING_EMAILS_ENABLED=false           # Enable automated onboarding drip campaign for new signups. Default: from ATLAS_DEPLOY_ENV profile (prod: true, staging/dev: false).
# ATLAS_UNSUBSCRIBE_TOKEN_TTL_MS=2592000000       # TTL for signed unsubscribe links (default: 30 days; range: 60s–1y)

# === Transactional email durable outbox (#2942) ===
# Password-reset / signup-verification emails are sent via a durable `email_outbox`: when the
# in-process retry (fetchWithRetry, #2949) is exhausted on a SUSTAINED provider outage, the send is
# enqueued and a Scheduler-backed flusher re-sends it on a later tick, rather than being dropped.
# ATLAS_EMAIL_OUTBOX_TICK_SECONDS=5           # Flusher poll interval. Default 5s; clamped to [1, 3600]. Out-of-range values clamp and log a warn.
# ATLAS_EMAIL_OUTBOX_WARN_THRESHOLD=50        # Pending-row threshold for the rate-limited backlog warning. Above this many `email_outbox` rows in `pending`, the flusher emits one `log.warn`/minute with the depth + oldest pending age. Pair with the `atlas.email_outbox.pending_count` gauge. Out-of-range clamps to [1, 1_000_000].
# ATLAS_EMAIL_OUTBOX_FLUSHER_ENABLED=true     # Opt-out for the polling flusher. Default true on any pod with an internal DB. Recovery sweeps still run on boot/shutdown regardless, so flipping back to `true` inherits clean state. Requires DATABASE_URL (no internal DB = nothing to queue, flusher not started).

# === Twenty CRM (SaaS-side lead capture — #2727) ===
# TWENTY_BASE_URL=https://crm.useatlas.dev   # Twenty REST base URL (defaults to crm.useatlas.dev). Self-hosters set to their own Twenty hostname.
# TWENTY_API_KEY=                            # Bearer key from Twenty Settings → API & Webhooks. Required for SaaS demo / signup / contact-form dispatch into Twenty; unset = SaasCrm.available is false. Twenty Person object must have custom fields `atlasFirstSource` AND `atlasLastSource` (verified at boot).
# ATLAS_CRM_OUTBOX_WARN_THRESHOLD=100        # Pending-row threshold for the rate-limited backlog warning (#2734). When the flusher sees more than this many `crm_outbox` rows in `pending` status, it emits one `log.warn` per minute with the depth + oldest pending row's age. Pair with the `atlas.crm_outbox.pending_count` gauge for dashboards. Out-of-range values clamp to [1, 1_000_000] and log a warn.
# ATLAS_CRM_OUTBOX_BACKSTOP_SWEEP_SECONDS=300 # Backstop sweep interval for the edge-triggered flusher (#2874). The flusher is NOT a poll loop — it wakes on the inline kick from `enqueue` and on per-row retry timers — so this is only the low-frequency safety net that re-claims a row whose retry timer was lost to a pod restart (or a crash-recovered `in_flight` row). Default 300s (5 min); an idle pod then issues ~288 claims/day instead of the old ~17,280 polls/day. Clamped to [1, 86400] (1s … 24h); out-of-range values clamp and log a warn.
# ATLAS_CRM_OUTBOX_FLUSHER_ENABLED=true      # Region gate for the flusher. Default true. Set `false` on regional API pods (e.g. api-eu / api-apac) whose internal `crm_outbox` is permanently empty — the lead-capture pipeline at crm.useatlas.dev writes only to US. With the flusher disabled the inline kick AND the backstop sweep are both skipped (only recovery runs), so a permanently-empty regional table issues zero flusher statements. Recovery sweeps still run on boot/shutdown regardless of this flag, so flipping it back to `true` later inherits clean state.

# === Talk-to-sales form (#2730) + self-serve MCP trial (#3649–#3654) ===
# Server side (api): verifies Cloudflare Turnstile tokens submitted by the
# /pricing dialog AND the `start_trial` MCP onboarding bootstrap. Required on
# Atlas SaaS; unset = POST /api/v1/contact AND every `start_trial` attempt
# return 403 (fail-closed — bot protection that silently passes is worse
# than a closed form). Get the secret key from the Cloudflare dashboard:
# https://dash.cloudflare.com/?to=/:account/turnstile
# TURNSTILE_SECRET_KEY=
# ATLAS_CONTACT_RATE_LIMIT_RPM=5             # Per-IP rate limit on /api/v1/contact (default 5/min, 0 = disabled).
# ATLAS_TRIAL_IP_RATE_LIMIT_RPM=5            # Per-IP self-serve trial creation-ATTEMPT limit (default 5/min, 0 = disabled). Bounds attempt rate, NOT trials — shared NATs are not capped. Hot-reloadable via the settings registry (Admin → Rate Limiting); env is the boot default.
# ATLAS_TRIAL_EMAIL_RATE_LIMIT_RPM=3         # Per-email self-serve trial creation-ATTEMPT limit (default 3/min, 0 = disabled). The tighter bound — one mailbox retrying is the spam signal. Hot-reloadable via the settings registry; env is the boot default.
# Client side (apps/www): paired site key — public, embedded in the
# Talk-to-sales widget script tag. Same Cloudflare dashboard URL above.
# When unset, the form renders a dev-mode notice and blocks submission.
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# NEXT_PUBLIC_ATLAS_API_BASE=https://api.useatlas.dev  # www (apps/www) BUILD-TIME var: the API origin the landing page's talk-to-sales form POSTs /api/v1/contact to (talk-to-sales-form.tsx). Defaults to https://api.useatlas.dev. On www-staging this MUST be set to https://api.staging.useatlas.dev at BUILD time (www is built with NIXPACKS, so Railway service vars are present at build) — an unset value sends staging's contact submissions to the PROD API. NOTE: also read by sub-processor-webhook-button.tsx (its own unset-default is https://app.useatlas.dev), so this single var repoints BOTH www client components — set it once for the whole www-staging build.

# === Python Tool (optional) ===
# ATLAS_PYTHON_ENABLED=false                  # Enable the executePython agent tool (requires ATLAS_SANDBOX_URL)
# ATLAS_PYTHON_TIMEOUT=30000                  # Python execution timeout in ms (default: 30s)

# === REST Datasource — generic OpenAPI (slice 2, #2926) ===
# REST datasources are now installed per-workspace from Admin → Connections (a
# built-in `openapi-generic` catalog row, code-seeded everywhere). Credentials
# are encrypted at rest in `workspace_plugins.config`; the representation mode
# (operation-graph default vs semantic-yaml, the #2931 bake-off knob) is a
# per-install toggle, NOT an env var. The slice-1 `ATLAS_OPENAPI_TWENTY*` /
# `ATLAS_OPENAPI_REPRESENTATION` env shortcut has been RETIRED — install,
# representation mode, and the write allowlist are all PER-INSTALL config set in
# the admin UI, with no operator env knob. The lone exception is the global
# timeout CAP below, which applies across every install.
#
# Writes (slice 5, #2929) are OFF by default: an operation only executes a
# non-GET request if its operationId is in that install's `write_allowlist`, and
# every allowlisted write requires an in-chat confirm-before-write step before it
# fires. Configure the allowlist per-install in Admin → Connections.
# ATLAS_OPENAPI_TIMEOUT=30000                 # Global OpenAPI per-request timeout CAP in ms — bounds both spec probes and operation execution; a per-install timeout above this is rejected (default: 30s)
# ATLAS_OPENAPI_CONFIRM_TTL_SECONDS=600       # Lifetime of the single-use confirm-before-write token (#3007) — how long a staged REST write stays confirmable before it must be re-staged. Clamped [60, 3600] (default: 600 = 10m). Signed with the encryption keyset (ATLAS_ENCRYPTION_KEYS / ATLAS_ENCRYPTION_KEY / BETTER_AUTH_SECRET) — no separate signing secret
#
# Shared cross-workspace spec cache (#2970): a built-in data candidate's PUBLIC
# spec (Stripe/GitHub/Notion — credential withheld at probe) is downloaded +
# normalized ONCE across all workspaces, refreshed on a cadence by conditional GET
# (a 304 is free for every workspace). Generic admin-supplied installs are never
# shared. The cache is process-local; these tune its freshness + refresh cadence.
# ATLAS_OPENAPI_SHARED_SPEC_TTL_MS=3600000    # Freshness window for the install-time short-circuit — within it a fresh install of an already-cached public upstream skips the network entirely (default: 1h)
# ATLAS_OPENAPI_SPEC_REFRESH_INTERVAL_HOURS=24 # Cadence of the periodic conditional-GET refresh of the shared public-spec cache (mirrors the BYOT / semantic-expert scheduler; default: 24h)
#
# Per-install auto re-discovery (#2978, Tier-2): a separate scheduler re-probes each
# installed generic OpenAPI datasource whose per-install spec_refresh_interval (set
# in Admin → Connections: off / daily / weekly / "<N>h") has elapsed, refreshing its
# persisted snapshot + drift diff. Distinct from the shared-cache refresh above — it
# mutates each install's own snapshot. This tunes the LOOP wake cadence, not the
# per-install interval; keep it at/below the smallest per-install interval you set.
# ATLAS_OPENAPI_REDISCOVER_INTERVAL_HOURS=1   # How often the loop wakes to scan for due installs (default: 1h)
#
# SSRF egress guard (#3006): host-side spec probes AND operation execution are
# blocked from reaching private / loopback / link-local / CGNAT IPs and internal
# hostnames (e.g. cloud metadata at 169.254.169.254). The guard is ON in every
# deploy mode and re-validates the resolved base URL + every redirect hop right
# before each fetch. Self-hosted operators who legitimately connect an internal
# OpenAPI service opt OUT explicitly with the flag below — NEVER set it on SaaS.
# ATLAS_OPENAPI_ALLOW_INTERNAL_HOSTS=false    # Set =true to allow OpenAPI datasources to target private/internal/non-HTTPS hosts (self-hosted only; default: false = fail-closed)

# === Webhook Plugin (optional) ===
# The webhook action/publisher plugins (plugins/webhook, plugins/webhook-action)
# sign deliveries with an operator-chosen secret. These are NOT auto-read by the
# host — you pass them explicitly to the plugin config in atlas.config.ts, e.g.
#   webhookPlugin({ secret: process.env.WEBHOOK_SECRET! })
#   webhookActionPlugin({ signing_secret: process.env.WEBHOOK_SIGNING_SECRET! })
# The variable NAMES are a convention (non-ATLAS_-prefixed); name them whatever
# you wire in atlas.config.ts. Documented here so the env-fallback path is visible.
# WEBHOOK_SECRET=                             # HMAC signing secret for the inbound webhook plugin (plugins/webhook)
# WEBHOOK_SIGNING_SECRET=                     # HMAC signing secret for the webhook-action plugin (plugins/webhook-action)
#
# SSRF egress guard for async webhook CALLBACKS (#3347): the per-request
# callbackUrl is a request-body-controlled fetch target, so the webhook plugin
# resolves it and blocks private / loopback / link-local / CGNAT IPs and internal
# hostnames (e.g. cloud metadata at 169.254.169.254), HTTPS-only, redirects never
# followed — the exact twin of ATLAS_OPENAPI_ALLOW_INTERNAL_HOSTS above. The guard
# is ON by default (fail-closed). Self-hosted operators who legitimately deliver to
# an internal/dev callback opt OUT explicitly with the flag below — NEVER set it on
# SaaS (source: plugins/webhook/src/callback-guard.ts).
# ATLAS_WEBHOOK_ALLOW_INTERNAL_CALLBACKS=false  # Set =true to allow webhook callbacks to target private/internal/non-HTTPS hosts (self-hosted only; default: false = fail-closed)
# ATLAS_WEBHOOK_REPLAY_LEGACY=false           # Migration-only soft-fail for the replay-protection wire change (#3347): when =true,
#                                             # inbound webhooks MISSING the X-Webhook-Timestamp header are accepted (with a warn)
#                                             # instead of rejected, so an upstream sender can be upgraded without downtime. Leave
#                                             # at the default (false = strict timestamp/HMAC replay protection) once senders are upgraded.

# === Appearance ===
# ATLAS_BRAND_COLOR=oklch(0.759 0.148 167.71)  # Primary brand color in oklch format

# === Multi-Tenancy ===
# ATLAS_ORG_ID=                               # CLI-only: org-scoped semantic layer selection (reads/writes semantic/.orgs/{orgId}/)
# ATLAS_INVITATION_LIMIT_PER_ORG=100          # Max pending invitations per organization. Issuing more returns the
#                                             # `invitation_limit` error until existing ones are accepted/cancelled.
#                                             # Non-positive/invalid values fall back to 100.
# ATLAS_TEAM_PG_URL=                          # Operator-CLI ONLY: canonical tenant-DB connection string for `atlas ops`
#                                             # (wipe, etc.), `atlas proactive`, `atlas seed`, and one-shot backfill
#                                             # scripts. Precedence: ATLAS_TEAM_PG_URL → DATABASE_URL → error. Set this
#                                             # explicitly before any DESTRUCTIVE subcommand — the DATABASE_URL fallback
#                                             # can target the wrong database. NOT read by the API process.

# === Settings ===
# ATLAS_SETTINGS_REFRESH_INTERVAL=30000       # Hot-reload interval for settings in ms (default: 30s). Set 0 to disable
# ATLAS_HEALTH_PLUGIN_CACHE_TTL_MS=15000      # TTL (ms) for the plugin-liveness health cache (lib/plugins/registry.ts). Default
#                                             # 15000 (15s); 0 disables caching (every call re-probes upstream). Max accepted
#                                             # value 300000 (5m); values above the max or unparseable fall back to the default with a warn

# === Scheduler ===
# ATLAS_SCHEDULER_ENABLED=false               # Enable scheduled task execution
# ATLAS_SCHEDULER_SECRET=                     # Shared secret for the /tick endpoint (non-Vercel)
# CRON_SECRET=                                # Vercel-native alternative to ATLAS_SCHEDULER_SECRET
# ATLAS_SCHEDULER_BACKEND=bun                 # Scheduler backend: bun | webhook | vercel
# ATLAS_SCHEDULER_MAX_CONCURRENT=5            # Max concurrent scheduled task executions
# ATLAS_SCHEDULER_TIMEOUT=60000               # Scheduled task timeout in ms (default: 60s)
# ATLAS_SCHEDULER_TICK_INTERVAL=60            # Tick engine interval in seconds (default: 60)
# ATLAS_ORPHAN_TASK_RECONCILE=false           # Auto-delete plugin scheduled_tasks orphaned by a failed uninstall (default: off — the orphan count is always observed via the atlas.scheduler.orphan_task_reconcile span + log.warn; only the destructive sweep is gated)

# === Networking ===
# ATLAS_PUBLIC_URL=https://api.example.com    # Public base URL for action approval URLs (derived from request headers when unset)
# ATLAS_PUBLIC_API_URL=https://api.example.com  # Public origin of the API host itself. resolvePublicApiUrl() (integrations/install/register.ts) builds EVERY OAuth install handler's redirect URI from this (Slack/Jira/Linear/Salesforce/GitHub App). When unset, it is derived from ATLAS_API_REGION + residency.regions[].apiUrl (#3706 — so SaaS no longer stamps it per regional service); if no region is configured either, those handlers log "not registered" at boot and their install routes return 501. ATLAS_CORS_ORIGIN is the WEB app origin and is intentionally NOT a fallback — in split-origin SaaS deploys the two diverge and a CORS-origin fallback would mint a redirect on the wrong host (invalid_redirect_uri). Also read by the MCP/OAuth well-known documents.

# === Production Deployment ===
# Required for production (Railway, etc.):
#   ATLAS_PROVIDER + its API key (e.g. ANTHROPIC_API_KEY)
#   ATLAS_DATASOURCE_URL=postgresql://user:pass@host:5432/dbname
#   DATABASE_URL=postgresql://user:pass@host:5432/atlas  (Atlas internals — most platforms auto-provision this)
#
# Optional (defaults are fine for most deployments):
#   ATLAS_MODEL, ATLAS_ROW_LIMIT, ATLAS_QUERY_TIMEOUT
#   PORT (set automatically by most platforms)

# === Observability ===
# ATLAS_LOG_LEVEL=info                              # debug | info | warn | error
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318 # OTLP HTTP — traces + metrics exported only when set (one endpoint drives both)
# OTEL_EXPORTER_OTLP_HEADERS="authorization=Bearer%20<token>"  # Auth header(s) your collector requires (W3C Baggage format — percent-encode spaces, e.g. %20). Set per-service in prod.

# === Runtime ===
# ATLAS_MIGRATION_RETRIES=5                       # Retry count for internal DB migrations at startup (default: 5, 0 = disabled)
# ATLAS_RUNTIME=vercel    # Force Vercel Sandbox for explore tool (auto-detected on Vercel)

# === CORS ===
# ATLAS_CORS_ORIGIN=https://app.example.com  # Required when frontend and API are on different origins. Enables credentials (cookies) for managed auth. Also a runtime registry setting (Admin → Security). When unset, the default derives from ATLAS_API_REGION + residency.regions[].apiUrl (web origin, #3706) on SaaS, else the wildcard "*" (fine for header/API-key auth).

# === API URL (dev rewrite target) ===
# Used by Next.js rewrites to proxy /api/* to the Hono API server.
# Default: http://localhost:3001 (matches `bun run dev` fixed port)
# ATLAS_API_URL=http://localhost:3001

# === Public Web URL (optional) ===
# Public-facing web URL used in user-visible link prompts (e.g. the
# proactive listener's "link your Atlas account" DM CTA). Defaults to
# the SaaS host; set this on self-hosted deploys with a custom domain.
# ATLAS_PUBLIC_WEB_URL=https://app.useatlas.dev
# ATLAS_WEB_BASE_URL=http://localhost:3000    # Base URL the screenshotDashboard vision tool (#2367) renders against —
#                                             # it builds ${ATLAS_WEB_BASE_URL}/dashboards/:id for the headless Chromium
#                                             # worker. Set to the production web origin when self-hosting. Default: localhost:3000.
# ATLAS_INTERNAL_SCREENSHOT_COOKIE=           # Service cookie the screenshotDashboard worker presents when it calls back
#                                             # into /admin/dashboards/:id/screenshot to authenticate as the requesting
#                                             # user. Without it the screenshot is rejected and the agent falls back to its
#                                             # last-good description. Set on BOTH the API and web services behind a proxy.

# === Frontend API URL (optional) ===
# When set, the frontend calls the API directly (cross-origin).
# When unset, the frontend uses same-origin relative URLs
# (proxied to the API via Next.js rewrites — see ATLAS_API_URL above).
# NOTE: On Vercel, deploy the API server separately (e.g. as a standalone Bun service)
# and set NEXT_PUBLIC_ATLAS_API_URL. The Next.js rewrite proxy does not support
# maxDuration for long-running agent loops.
# NEXT_PUBLIC_ATLAS_API_URL=https://api.example.com
# NEXT_PUBLIC_ATLAS_AUTH_MODE=managed          # Enables proxy-level route protection (redirects unauthenticated users to /login). Values: managed | (omit for no proxy enforcement)
# NEXT_PUBLIC_ATLAS_COOKIE_PREFIX=atlas        # Session-cookie name prefix the web proxy reads. MUST match the API's prefix (ATLAS_COOKIE_PREFIX / ATLAS_DEPLOY_ENV profile). Default: "atlas". Set per env when multiple Atlas envs share one parent domain (e.g. atlas-staging on app.staging.*). For local dev: atlas-dev.

# === Explore Tool Isolation ===
# Local dev: sandbox sidecar runs via docker compose (bun run db:up).
# Production: use the service hostname (e.g. http://sandbox-sidecar:8080).
# Comment out if not using Docker Compose (explore falls back to just-bash).
ATLAS_SANDBOX_URL=http://localhost:8080
# ATLAS_SANDBOX=nsjail    # Process isolation for explore tool (auto-detected when nsjail is on PATH)
# ATLAS_SANDBOX_PRIORITY=                        # Custom backend priority (comma-separated: vercel-sandbox,nsjail,sidecar,just-bash)
# ATLAS_SANDBOX_BACKEND=                         # SaaS admin-facing selector: vercel-sandbox | sidecar | e2b-sandbox | daytona-sandbox | <plugin-id>. Self-hosted operators typically use ATLAS_SANDBOX_PRIORITY instead
# SIDECAR_AUTH_TOKEN=                            # Shared secret for sidecar auth (set on both API and sidecar). The sidecar refuses to boot without it unless SIDECAR_AUTH_DISABLE=1 (loopback dev only)
# Vercel Sandbox access — required when calling @vercel/sandbox from off-Vercel
# hosts (Railway, Fly, external CI, etc.). On Vercel itself, OIDC handles auth
# via VERCEL_OIDC_TOKEN and these are unnecessary.
# The team + project IDs are NOT secret; SaaS bakes them into atlas.config.ts
# under `sandbox.vercel` (#3706) rather than stamping them per service. These
# env vars still override the config values when set (self-host points at its
# own Vercel account this way). Only VERCEL_TOKEN is secret and stays env-only.
# VERCEL_TEAM_ID=team_xxx                        # Overrides sandbox.vercel.teamId from config when set
# VERCEL_PROJECT_ID=prj_xxx                      # Overrides sandbox.vercel.projectId from config when set
# VERCEL_TOKEN=                                  # Vercel access token with sandbox scope (secret — env only)
# ATLAS_NSJAIL_PATH=      # Explicit path to nsjail binary (auto-detected on PATH otherwise)
# ATLAS_NSJAIL_TIME_LIMIT and ATLAS_NSJAIL_MEMORY_LIMIT are read by BOTH the explore
# tool (semantic FS sandbox) and the executePython tool, with different built-in defaults:
#   explore:        time_limit=10s,   memory_limit=256 MB
#   executePython:  time_limit=30s,   memory_limit=512 MB  (data-science workloads need more headroom)
# Setting either env var overrides BOTH backends with the same value. See
# docs/reference/environment-variables (Sandbox & Isolation) for the full split.
# ATLAS_NSJAIL_TIME_LIMIT=10     # nsjail per-command time limit in seconds (overrides both backends)
# ATLAS_NSJAIL_MEMORY_LIMIT=256  # nsjail per-command memory limit in MB (overrides both backends)

# === BYOC Sandbox & Reader Plugin Credentials (optional) ===
# Credentials for the BYOC sandbox runtimes (e2b, daytona — shipped in the SaaS
# image, selectable via ATLAS_SANDBOX_BACKEND) and the Obsidian reader plugin.
# These are NOT auto-read by the host — you pass them explicitly to the plugin
# config in atlas.config.ts, e.g.
#   e2bSandboxPlugin({ apiKey: process.env.E2B_API_KEY! })
#   daytonaSandboxPlugin({ apiKey: process.env.DAYTONA_API_KEY! })
#   obsidianReaderPlugin({ api_key: process.env.OBSIDIAN_API_KEY! })
# The variable NAMES are a convention — name them whatever you wire in atlas.config.ts.
# E2B_API_KEY=                                   # E2B sandbox API key (plugins/e2b)
# DAYTONA_API_KEY=                               # Daytona sandbox API key (plugins/daytona)
# OBSIDIAN_API_KEY=                              # Obsidian Local REST API key (plugins/obsidian-reader)

# === Action Framework (optional) ===
# ATLAS_ACTIONS_ENABLED=true                  # Enable action framework (requires auth)
# ATLAS_ACTION_APPROVAL=manual                # Default approval mode: auto | manual | admin-only
# ATLAS_ACTION_TIMEOUT=300000                 # Action execution timeout in ms (transitions to timed_out on expiry)
# ATLAS_ACTION_MAX_PER_CONVERSATION=10        # Max actions per conversation (reserved, not yet enforced)

# === Slack Integration (optional) ===
# SLACK_SIGNING_SECRET=               # Enables Slack routes when set
# SLACK_BOT_TOKEN=                    # Single-workspace mode (skip OAuth)
# SLACK_CLIENT_ID=                    # Multi-workspace OAuth
# SLACK_CLIENT_SECRET=                # Multi-workspace OAuth
# SLACK_ENCRYPTION_KEY=               # 32 bytes (hex64 or base64) — encrypts
#                                     # bot tokens stored in chat_cache.
#                                     # Required for multi-workspace prod;
#                                     # without it tokens persist as plaintext.
# ATLAS_SLACK_INSTALL_TABLE=          # Override the table the OAuth callback
#                                     # writes installs to. Defaults to
#                                     # `chat_cache` — must match the chat
#                                     # plugin's `state.tablePrefix` + `cache`
#                                     # (e.g. `tablePrefix: "myorg_"` →
#                                     # `ATLAS_SLACK_INSTALL_TABLE=myorg_cache`).

# === Discord Integration (optional) ===
# Cap-gated static-bot install: set DISCORD_BOT_TOKEN + DISCORD_CLIENT_ID to
# enable the bot install at /api/v1/integrations/discord/install. The legacy
# OAuth connect flow (DISCORD_CLIENT_SECRET) was retired in #3145 (now 410 Gone).
# DISCORD_CLIENT_ID=                  # Discord application (client) ID — enables the Discord install route + admin card when set
# DISCORD_BOT_TOKEN=                  # Discord bot token — required (with DISCORD_CLIENT_ID) for the static-bot install + adapter outbound calls
# DISCORD_PUBLIC_KEY=                 # Discord app public key — required by the chat adapter to verify inbound webhook signatures
# DISCORD_OAUTH_PERMISSIONS=274877991936  # Optional override for the bot OAuth permission bitmask in the install authorize URL (default: 274877991936)

# === Teams Integration (optional) ===
# The Teams chat adapter requires BOTH vars (plugins/chat/src/adapter-registry.ts requiredEnv:
# ["TEAMS_APP_ID","TEAMS_APP_PASSWORD"]) — with either unset the adapter won't build and the webhook
# returns "adapter not configured", so installs/webhooks are non-routable.
# TEAMS_APP_ID=                       # Microsoft Teams (Entra ID) app ID
# TEAMS_APP_PASSWORD=                 # Teams app client secret — required by the chat adapter to build/route

# === Telegram Integration (optional) ===
# Static-bot install (/api/v1/integrations/telegram/install) + inbound-webhook verification.
# Read by integrations/install/register.ts; an enabled `telegram` catalog row with the token
# unset returns 501 and the adapter is skipped.
# TELEGRAM_BOT_TOKEN=                 # Telegram Bot API token (from @BotFather) — registers the install handler + adapter
# TELEGRAM_WEBHOOK_SECRET=            # Secret echoed in X-Telegram-Bot-Api-Secret-Token on inbound updates; the
#                                     # AdapterRegistry requires it to build the adapter. With the token set but this
#                                     # unset, installs succeed yet inbound updates are dropped (forgery-safe).

# === WhatsApp Integration (optional) ===
# WhatsApp (Meta Business): the two META_BUSINESS_* vars gate the static-bot install
# (/api/v1/integrations/whatsapp/install); the chat adapter additionally needs the two webhook
# secrets below. adapter-registry.ts requires ALL FOUR — with any unset the adapter won't build, so
# installs can succeed yet inbound webhooks never activate.
# META_BUSINESS_ACCESS_TOKEN=         # Meta Business access token (sent as Authorization: Bearer to the Meta Graph API)
# META_BUSINESS_APP_ID=               # Operator's Meta App ID, used to validate the phone-number id at install time
# WHATSAPP_APP_SECRET=                # Meta App Secret for HMAC-SHA256 webhook signature verification (X-Hub-Signature-256)
# WHATSAPP_VERIFY_TOKEN=              # Random string pasted into the Meta webhook config; echoed back in the GET challenge handshake

# === Google Chat Integration (optional) ===
# Google Chat static-bot install (/api/v1/integrations/gchat/install) via service account + Pub/Sub.
# Both vars gate registration — an enabled `gchat` row with either unset (or malformed JSON) returns 501.
# GCHAT_SERVICE_ACCOUNT_JSON=         # Google service-account credentials JSON (parsed at boot) for the Pub/Sub round-trip + adapter
# GCHAT_PUBSUB_TOPIC=                 # Fully-qualified Pub/Sub topic name the Google Chat adapter publishes to
# Inbound HTTP-webhook JWT verification (plugins/chat/src/index.ts, #3350) — set at least ONE to accept verified inbound HTTP traffic.
# With BOTH unset the Google Chat HTTP webhook is REJECTED (fail-closed); the Pub/Sub push path the adapter binds at boot is unaffected.
# GCHAT_PROJECT_NUMBER=               # GCP project number — verifies JWTs on DIRECT Google Chat HTTP webhooks
# GCHAT_PUBSUB_AUDIENCE=              # Expected JWT audience — verifies JWTs on Pub/Sub PUSH delivery

# === JIRA Integration (optional) ===
# Requires ATLAS_ACTIONS_ENABLED=true
# JIRA_BASE_URL=https://yourorg.atlassian.net   # Jira instance URL
# JIRA_EMAIL=                                    # Jira account email for API auth
# JIRA_API_TOKEN=                                # Jira API token (generate at id.atlassian.com)
# JIRA_DEFAULT_PROJECT=                          # Default project key for issue creation (e.g. PROJ)

# === Jira Lazy OAuth Integration (1.5.2 / #2659) ===
# Distinct from the manual JIRA_API_TOKEN flow above — this is the
# per-Workspace OAuth 2.0 (3LO) integration registered under
# /api/v1/integrations/jira. Create an OAuth 2.0 (3LO) integration in the
# Atlassian Developer Console with at least `read:jira-work`,
# `read:jira-user`, and `offline_access` scopes; set the Callback URL to
# `${ATLAS_PUBLIC_API_URL}/api/v1/integrations/jira/callback`. Without
# these env vars, the install handler logs `Jira OAuth handler not
# registered` at boot and GET /api/v1/integrations/jira/install returns 501.
# JIRA_CLIENT_ID=                                # Atlassian App's Client ID
# JIRA_CLIENT_SECRET=                            # Atlassian App's Client Secret

# === Linear Lazy OAuth Integration (1.5.3 / #2750) ===
# Per-Workspace OAuth 2.0 integration registered under
# /api/v1/integrations/linear. Create an OAuth Application in Linear at
# https://linear.app/settings/api → "OAuth Applications" with at least
# `read`, `write`, and `issues:create` scopes; set the Callback URL to
# `${ATLAS_PUBLIC_API_URL}/api/v1/integrations/linear/callback`. Without
# these env vars, the install handler logs `Linear OAuth handler not
# registered` at boot and GET /api/v1/integrations/linear/install returns
# 501. The `linear-apikey` form-install path is independent and does NOT
# require these env vars — workspace admins paste a personal API key
# directly.
# LINEAR_CLIENT_ID=                              # Linear OAuth Application's Client ID
# LINEAR_CLIENT_SECRET=                          # Linear OAuth Application's Client Secret

# === Salesforce Integration (optional) ===
# Salesforce connected-app credentials for /api/v1/integrations/salesforce/install.
# When SALESFORCE_CLIENT_ID is unset, that endpoint returns 501.
# SALESFORCE_CLIENT_ID=                          # Salesforce connected-app consumer key
# SALESFORCE_CLIENT_SECRET=                      # Salesforce connected-app consumer secret (pair with CLIENT_ID)
# SALESFORCE_LOGIN_URL=https://login.salesforce.com  # Override for sandboxes (e.g. https://test.salesforce.com). Default: production login host

# === GitHub Data integration (GitHub App) ===
# DISTINCT from the social-login GITHUB_CLIENT_ID / GITHUB_CLIENT_SECRET above
# (those are for Better Auth sign-in). These configure the multi-tenant GitHub
# App action integration (create issues / open PRs), read by
# integrations/install/register.ts. When the `github` catalog row is enabled
# but any of the five below is unset, /api/v1/integrations/github/install
# returns 501 (the handler logs "not registered" at boot). Register a GitHub
# App at https://github.com/settings/apps; set the callback URL to
# `${ATLAS_PUBLIC_API_URL}/api/v1/integrations/github/callback`.
# GITHUB_APP_ID=                                 # Numeric App ID from the App settings page
# GITHUB_APP_SLUG=                               # App slug from https://github.com/apps/<slug>
# GITHUB_APP_PRIVATE_KEY=                        # App private key (.pem contents); also used to mint short-lived installation tokens at query time
# GITHUB_APP_CLIENT_ID=                          # App OAuth Client ID (for the per-workspace install consent flow)
# GITHUB_APP_CLIENT_SECRET=                      # App OAuth Client Secret (pair with GITHUB_APP_CLIENT_ID)
# GITHUB_APP_INSTALLATION_ID=                    # Self-host single-tenant ONLY (github-single-tenant catalog row): pins the App's install to one org. Not used by the multi-tenant `github` row.

# === Stripe Billing (SaaS only) ===
# Enables Stripe billing when STRIPE_SECRET_KEY is set. Self-hosted deployments
# skip this entirely — the self-hosted experience is the free tier.
# Only the two genuine secrets live in env. The six per-tier Price IDs are
# now platform settings (Admin → Settings → Billing) — editable at runtime
# without a redeploy (#3703). Setting them via env still works as a fallback.
# STRIPE_SECRET_KEY=sk_test_...                    # Stripe secret key (test or live)
# STRIPE_WEBHOOK_SECRET=whsec_...                  # Stripe webhook signing secret

# === Data Residency ===
# ATLAS_API_REGION=                   # Region identity of this API instance (e.g. "us-west", "eu-west", "ap-southeast"). Used for misrouting detection. Falls back to residency.defaultRegion from atlas.config.ts if unset.
# ATLAS_STRICT_ROUTING=false          # When true, misrouted requests receive 421 Misdirected Request instead of being served with a warning.
# ATLAS_INTERNAL_SECRET=              # Shared secret for cross-region service-to-service auth (required for region migration).

# === Deploy Mode ===
# ATLAS_DEPLOY_MODE=                          # Deploy mode: self-hosted | saas (auto-detected when unset). Self-host only —
#                                             # the hosted SaaS sets deployMode in deploy/api/atlas.config.ts, not this env var (#3702).
# ATLAS_DEPLOY_ENV=production                 # Deployment shape: production | staging | development (unset = production).
#                                             # Drives non-secret per-env defaults via packages/api/src/lib/env-profile.ts —
#                                             # prod defaults email-verification ON + onboarding-emails ON; staging/dev default both OFF;
#                                             # session-cookie prefix prod=atlas, staging=atlas-staging, dev=atlas-dev;
#                                             # rate-limit RPM (prod/dev: disabled, staging: 300). It ALSO centralizes
#                                             # hosted-MCP max sessions, the staging mail sink, and demo-seed-on-boot —
#                                             # but those are identical across every env today (flat 100, the sink below,
#                                             # off) and only live here so a future env can diverge; ATLAS_DEPLOY_ENV
#                                             # does not change them yet.
#                                             # The per-var legacy overrides (ATLAS_REQUIRE_EMAIL_VERIFICATION,
#                                             # ATLAS_ONBOARDING_EMAILS_ENABLED, ATLAS_COOKIE_PREFIX, ATLAS_RATE_LIMIT_RPM,
#                                             # ATLAS_MCP_MAX_SESSIONS, STAGING_MAIL_SINK, ATLAS_SEED_DEMO) still win when explicitly set.
# ATLAS_COOKIE_PREFIX=                        # Override the per-env session-cookie name prefix (advanced.cookiePrefix). Non-empty wins over the ATLAS_DEPLOY_ENV profile.
#                                             # MUST equal the web service's NEXT_PUBLIC_ATLAS_COOKIE_PREFIX. Distinct prefixes keep prod & staging
#                                             # (which share the .useatlas.dev cookie zone) from colliding on one cookie slot.

# === Staging seed (SaaS staging region only) ===
# Read by the staging seed (packages/api/src/lib/staging/seed.ts) + the
# staging-smoke harness (.github/workflows/staging-smoke.yml). Only meaningful
# on the api-staging service (ATLAS_DEPLOY_ENV=staging + ATLAS_API_REGION=staging);
# inert everywhere else. The seeded admin EMAIL is a FIXED constant —
# admin@staging.useatlas.dev (STAGING_ADMIN_EMAIL in seed.ts) — NOT env-configurable;
# only the password below is read from env.
# STAGING_ADMIN_PASSWORD=                     # Password for the seeded staging admin (admin@staging.useatlas.dev). Unset = the admin user is NOT seeded (seed logs a warn and skips).
# STAGING_MAIL_SINK=staging-mail@useatlas.dev # Sink address the StagingClamp redirects ALL outbound recipients to so a soak can never email a real address (lib/staging/clamp.ts). Default: staging-mail@useatlas.dev. Empty/whitespace falls back to the default.
# STAGING_TWENTY_API_KEY=                      # API key for the STAGING Twenty CRM workspace. Unset = the staging seed skips the Twenty install.
# STAGING_TWENTY_BASE_URL=                     # Base URL of the STAGING Twenty instance (its own workspace, never prod's crm.useatlas.dev). Required alongside STAGING_TWENTY_API_KEY for the Twenty install.
# NOTE: STAGING_DATABASE_URL + STAGING_SLACK_WEBHOOK_URL are CI-only secrets for
# the staging-smoke workflow (set in GitHub Actions, not in this file).

# === Enterprise Features ===
# ATLAS_ENTERPRISE_ENABLED=false      # Enable enterprise features (SSO, SCIM, PII detection, custom roles). Self-host only —
#                                     # the hosted SaaS sets enterprise.enabled in deploy/api/atlas.config.ts, not this env var (#3702).
# ATLAS_ENTERPRISE_LICENSE_KEY=       # License key for enterprise features (https://www.useatlas.dev/enterprise)
# ATLAS_APPROVAL_EXPIRY_HOURS=24     # Hours before pending approval requests auto-expire
# ATLAS_SCIM_OVERRIDE_POLICY=strict  # F-57 SCIM provenance gate. "strict" blocks admin mutations on
#                                    # SCIM-provisioned users (409 SCIM_MANAGED). "override" allows the
#                                    # mutation but stamps the audit row with metadata.scim_override = true.
#                                    # No-op for workspaces with no SCIM provider configured. Default: strict.

# === Enterprise — SLA Monitoring ===
# ATLAS_SLA_LATENCY_P99_MS=          # P99 latency threshold in ms (fires SLA alerts when exceeded)
# ATLAS_SLA_ERROR_RATE_PCT=          # Error rate threshold as percentage 0-100 (fires SLA alerts when exceeded)
# ATLAS_SLA_WEBHOOK_URL=             # Webhook URL for SLA alert notifications
# ATLAS_SLA_WEBHOOK_SECRET=          # HMAC secret to sign SLA alert deliveries (X-Webhook-Signature); unset = unsigned

# === Enterprise — Backups ===
# ATLAS_BACKUP_SCHEDULE=0 3 * * *    # Cron expression for automated backups (default: daily at 3am)
# ATLAS_BACKUP_RETENTION_DAYS=30     # Days to retain backups (default: 30)
# ATLAS_BACKUP_STORAGE_PATH=./backups  # Backup storage directory (default: ./backups)
# ATLAS_BACKUP_VERIFY_SCRATCH_URL=   # Postgres URL of a DISPOSABLE scratch DB for restore-into-scratch
#                                    # backup verification (#2941). When set, verifyBackup restores each
#                                    # dump into this DB and counts base tables, so "verified" means
#                                    # "restorable". When unset, verification degrades to a pg_dump
#                                    # header-only check (logs a warning). ⚠️ WIPES the scratch DB's public
#                                    # schema on every run — point it at a throwaway DB only, never a
#                                    # real/prod database. As a safety net, verification REFUSES to run if
#                                    # this resolves to the same {host,port,db} as DATABASE_URL.

# === Status Page (optional) ===
# External status page for incident communication. When set, the built-in
# status page redirects here and the app shows incident banners from the feed.
# NEXT_PUBLIC_STATUS_URL=https://atlas.openstatus.dev
# NEXT_PUBLIC_OPENSTATUS_SLUG=atlas        # OpenStatus status page slug for JSON feed

# === Sub-Processor Publisher (optional) ===
# Fetches Atlas's authoritative sub-processor list (third-party vendors that
# process customer data) and surfaces it on the public docs/legal page.
# Self-hosted operators rarely touch these — defaults mirror the SaaS config.
# ATLAS_SUBPROCESSORS_URL=                            # Override the source URL the publisher fetches. Default: built-in source URL
# ATLAS_SUBPROCESSOR_PUBLISH_INTERVAL_MS=21600000     # Refresh interval for the publisher loop in ms. Default: 21600000 (6h)

# === Railway Custom Domains ===
# Required for custom domain support (enterprise feature). Get these from your Railway dashboard.
# RAILWAY_API_TOKEN=                  # Workspace-scoped Railway API token
# RAILWAY_PROJECT_ID=                 # Railway project ID for the Atlas deployment
# RAILWAY_ENVIRONMENT_ID=             # Railway environment ID (production)
# RAILWAY_WEB_SERVICE_ID=             # Railway service ID for the web service (domains point here)

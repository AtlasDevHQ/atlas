{
  "name": "@atlas/api",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "exports": {
    "./app": "./src/api/index.ts",
    "./lib/semantic": "./src/lib/semantic/index.ts",

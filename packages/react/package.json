{
  "name": "@useatlas/react",
  "version": "0.0.1",
  "description": "Embeddable Atlas chat UI for React applications",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./hooks": "./src/hooks/index.ts",
    "./widget": "./src/global.d.ts",
    "./styles.css": "./src/styles.css"
  },
  "publishConfig": {
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "import": {
          "types": "./dist/index.d.ts",
          "default": "./dist/index.js"
        },
        "require": {
          "types": "./dist/index.d.cts",
          "default": "./dist/index.cjs"
        }
      },
      "./hooks": {
        "import": {
          "types": "./dist/hooks.d.ts",
          "default": "./dist/hooks.js"
        },
        "require": {
          "types": "./dist/hooks.d.cts",
          "default": "./dist/hooks.cjs"
        }
      },
      "./widget": {
        "types": "./dist/global.d.ts"
      },
      "./styles.css": "./dist/styles.css"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "build": "tsup && cp src/styles.css dist/styles.css && cp src/global.d.ts dist/global.d.ts && mkdir -p dist/lib && cp src/lib/widget-types.ts dist/lib/widget-types.d.ts && bun x @tailwindcss/cli -i src/widget.css -o dist/widget.css --minify",
    "dev": "tsup --watch",
    "test": "bun scripts/test-isolated.ts",
    "type": "tsc --noEmit"
  },
  "peerDependencies": {
    "@ai-sdk/react": ">=3.0.0",
    "ai": ">=6.0.0",
    "lucide-react": ">=0.400.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "react-syntax-highlighter": ">=15.0.0",
    "recharts": ">=2.0.0",
    "tailwindcss": ">=4.0.0",
    "xlsx": ">=0.18.0"
  },
  "peerDependenciesMeta": {
    "lucide-react": {
      "optional": true
    },
    "react-syntax-highlighter": {
      "optional": true
    },
    "recharts": {
      "optional": true
    },
    "tailwindcss": {
      "optional": true
    },
    "xlsx": {
      "optional": true
    }
  },
  "dependencies": {
    "@useatlas/types": "workspace:*",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "radix-ui": "^1.4.3",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@ai-sdk/react": "^3.0.99",
    "@tailwindcss/cli": "^4.2.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "ai": "^6.0.97",
    "happy-dom": "16.6.0",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-syntax-highlighter": "^16.1.0",
    "recharts": "^3.7.0",
    "tailwindcss": "^4.2.1",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "xlsx": "^0.18.5"
  }
}

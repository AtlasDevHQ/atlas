# === LLM Provider (pick one) ===
# ATLAS_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# ATLAS_PROVIDER=openai
# OPENAI_API_KEY=sk-...

# ATLAS_PROVIDER=bedrock
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...

# ATLAS_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434

# === Model (optional, provider-specific default used if omitted) ===
# ATLAS_MODEL=claude-sonnet-4-6

# === Database ===
# ATLAS_DB=sqlite              # Default: built-in SQLite demo

# Local dev with Docker Postgres (bun run db:up):
# ATLAS_DB=postgres
# DATABASE_URL=postgresql://atlas:atlas@localhost:5432/atlas

# Production: point to your managed Postgres
# ATLAS_DB=postgres
# DATABASE_URL=postgresql://user:pass@your-host:5432/yourdb

# === Security ===
# ATLAS_READ_ONLY=true         # Default: true — reject all non-SELECT SQL
# ATLAS_TABLE_WHITELIST=true   # Default: true — only allow tables defined in semantic layer
# ATLAS_ROW_LIMIT=1000         # Default: 1000
# ATLAS_QUERY_TIMEOUT=30000    # Default: 30s in milliseconds

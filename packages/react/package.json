{
  "name": "@useatlas/react",
  "version": "0.0.7",
  "description": "Embeddable Atlas chat UI for React applications",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AtlasDevHQ/atlas",
    "directory": "packages/react"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./hooks": {
      "import": {
        "types": "./dist/hooks.d.ts",
        "default": "./dist/hooks.js"
      },
      "require": {
        "types": "./dist/hooks.d.cts",
        "default": "./dist/hooks.cjs"
      }
    },
    "./widget": {
      "types": "./dist/global.d.ts"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "build": "tsup && cp src/styles.css dist/styles.css && cp src/global.d.ts dist/global.d.ts && mkdir -p dist/lib && cp src/lib/widget-types.ts dist/lib/widget-types.d.ts && bun x @tailwindcss/cli -i src/widget.css -o dist/widget.css --minify",
    "dev": "tsup --watch",
    "test": "bun scripts/test-isolated.ts",
    "type": "tsc --noEmit"
  },
  "peerDependencies": {
    "@ai-sdk/react": ">=3.0.0",
    "ai": ">=6.0.0",
    "lucide-react": ">=0.400.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "react-syntax-highlighter": ">=15.0.0",
    "recharts": ">=2.0.0",
    "tailwindcss": ">=4.0.0",
    "exceljs": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "lucide-react": {
      "optional": true
    },
    "react-syntax-highlighter": {
      "optional": true
    },
    "recharts": {
      "optional": true
    },
    "tailwindcss": {
      "optional": true
    },
    "exceljs": {
      "optional": true
    }
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-query": "^5.96.2",
    "@useatlas/types": "^0.0.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "radix-ui": "^1.4.3",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@ai-sdk/react": "^3.0.143",
    "@tailwindcss/cli": "^4.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "ai": "^6.0.141",
    "exceljs": "^4.4.0",
    "happy-dom": "20.8.9",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-syntax-highlighter": "^16.1.1",
    "recharts": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2"
  }
}

{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "examples/docker/Dockerfile",
    "dockerfileContext": "../..",
    "watchPatterns": [
      "packages/api/**",
      "packages/cli/data/**",
      "packages/plugin-sdk/**",
      "examples/docker/**",
      "semantic/**"
    ]
  },
  "deploy": {
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 60
  }
}
